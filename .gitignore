# ============================================================
#  .gitignore — Prashik Fulke Portfolio (Next.js 14)
# ============================================================

# ─── Dependencies ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Next.js Build Output ───────────────────────────────────
.next/
out/
build/
dist/

# ─── Environment Variables (NEVER commit secrets) ───────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ─── Production Build Artifacts ─────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS & Editor Junk ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.pem

# ─── IDE & Editor Config ────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/

# ─── Debug & Logs ───────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── Testing ────────────────────────────────────────────────
/coverage
.nyc_output

# ─── Misc ───────────────────────────────────────────────────
*.tgz
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.cache/
.turbo/
